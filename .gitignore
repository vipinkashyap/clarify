# Ignore everything under .cache/ except the two subdirs we commit —
# parsed papers + extracted figures, so `clarify bootstrap` (and CI)
# can skip the arxiv round-trip. Small and deterministic.
.cache/*
!.cache/parsed/
!.cache/figures/
__pycache__/
.venv/
eval/generated/*.json
*.pyc
*.egg-info/
.pytest_cache/
dist/
build/
.DS_Store
# Static build output — regenerated via `clarify build-static`.
# Uncomment the line below if you deploy to GitHub Pages from /docs/:
# !docs/index.html
